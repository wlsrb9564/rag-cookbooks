# ─── 필수 API 키 ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key      # Claude 사용 시 (권장)
OPENAI_API_KEY=your_openai_api_key            # OpenAI 사용 시 (노트북 기본값)

# ─── 검색 도구 ─────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key            # adaptive_rag, corrective_rag, react

# ─── 평가 도구 (선택) ──────────────────────────────────────
ATHINA_API_KEY=your_athina_api_key            # Athina AI 평가 (없으면 eval 셀 스킵)
LANGCHAIN_API_KEY=your_langsmith_api_key      # LangSmith 트레이싱 (fusion_rag)
LANGCHAIN_TRACING_V2=true

# ─── 특정 노트북 전용 (선택) ──────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key        # naive_rag 전용 (다른 노트북 불필요)
